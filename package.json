{
  "name": "ani-rec-ai",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@ani-rec-ai/db",
    "db:migrate": "turbo run db:migrate  --filter=@ani-rec-ai/db",
    "db:studio": "turbo run db:studio   --filter=@ani-rec-ai/db"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}