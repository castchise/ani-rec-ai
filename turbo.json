{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                ".next/**",
                "!.next/cache/**",
                "dist/**"
            ],
            "env": [
                "DATABASE_URL",
                "MAL_CLIENT_ID",
                "NOMIC_API_KEY"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true,
            "env": [
                "DATABASE_URL",
                "MAL_CLIENT_ID",
                "NOMIC_API_KEY"
            ]
        },
        "typecheck": {
            "dependsOn": [
                "^build"
            ],
            "outputs": []
        },
        "lint": {
            "outputs": []
        },
        "db:generate": {
            "cache": false
        },
        "db:migrate": {
            "cache": false
        },
        "db:push": {
            "cache": false
        },
        "db:studio": {
            "cache": false,
            "persistent": true,
            "env": [
                "DATABASE_URL"
            ]
        }
    }
}