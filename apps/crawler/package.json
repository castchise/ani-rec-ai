{
    "name": "@ani-rec-ai/crawler",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit",
        "seed": "pnpm exec tsx --env-file=../../.env src/seed.ts",
        "enrich": "pnpm exec tsx --env-file=../../.env src/enricher-worker.ts",
        "seed:enrich": "pnpm exec tsx --env-file=../../.env src/seed-enricher.ts"
    },
    "dependencies": {
        "@ani-rec-ai/db": "workspace:*",
        "@ani-rec-ai/api-clients": "workspace:*",
        "@ani-rec-ai/types": "workspace:*",
        "bullmq": "^5.7.0",
        "ioredis": "^5.3.0"
    },
    "devDependencies": {
        "@ani-rec-ai/config": "workspace:*",
        "tsx": "^4.10.0",
        "typescript": "^5.4.0"
    }
}